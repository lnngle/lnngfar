{
  "name": "lnngfar",
  "version": "0.1.0",
  "private": true,
  "description": "Blueprint-driven code generator",
  "main": "dist/src/cli/index.js",
  "bin": {
    "lnngfar": "bin/lnngfar.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "npm run build",
    "setup:link": "npm run build && npm link",
    "setup:unlink": "npm unlink -g lnngfar",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
