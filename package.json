{
  "name": "lnngfar",
  "version": "0.1.0",
  "private": true,
  "description": "Blueprint-driven code generator",
  "main": "dist/src/cli/index.js",
  "bin": {
    "lnngfar": "bin/lnngfar.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "npm run build",
    "setup:link": "npm run build && npm link",
    "setup:unlink": "npm unlink -g lnngfar",
    "test": "npm run test:unit && npm run test:integration",
    "test:coverage": "jest --runInBand --coverage tests/unit tests/integration tests/contract blueprints/lnngfar-blueprint-cocos/tests/generator.spec.ts",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand tests/integration tests/contract blueprints/lnngfar-blueprint-cocos/tests/generator.spec.ts",
    "test:e2e": "jest --runInBand tests/e2e",
    "test:template-tools": "node --test blueprints/lnngfar-blueprint-cocos/templates/tests/tools/*.test.js",
    "test:perf": "jest --runInBand tests/performance",
    "test:all": "npm run test && npm run test:e2e && npm run test:template-tools",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
